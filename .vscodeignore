# Development and CI files
.github/**
.vscode/**
tests/**
.gitignore
tsconfig.json
tslint.json

# TypeScript sources and build metadata
client/src/**
server/src/**
client/tsconfig.json
server/tsconfig.json
client/out/**/*.map
server/out/**/*.map
client/out/**/*.d.ts
server/out/**/*.d.ts
**/*.tsbuildinfo

# Lock files are not needed at runtime
package-lock.json
client/package-lock.json
server/package-lock.json
**/node_modules/.package-lock.json

# Nested development-only type packages
client/node_modules/@types/**
server/node_modules/@types/**
client/node_modules/undici-types/**
server/node_modules/undici-types/**

# Local artifacts and logs
*.vsix
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
