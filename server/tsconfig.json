{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": [
            "ES2020"
        ],
        "outDir": "out",
        "rootDir": "src",
        "sourceMap": true,
        "composite": true,
        "skipLibCheck": true,
        "strict": false,
        "strictFunctionTypes": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "out"
    ]
}
