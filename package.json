{
   "name": "rsl-plus",
   "displayName": "RSL-plus",
   "description": "RSL / Object RSL language support with diagnostics, navigation and Quick Fixes",
   "author": "Veniamin Rakov + AChumakov",
   "license": "SEE LICENSE IN LICENSE.txt",
   "version": "1.1.4",
   "icon": "icon.png",
   "bugs": {
      "url": "https://github.com/aschumakov/RSL-plus/issues"
   },
   "repository": {
      "type": "git",
      "url": "https://github.com/aschumakov/RSL-plus.git"
   },
   "publisher": "AChumakov",
   "categories": [
      "Programming Languages",
      "Snippets"
   ],
   "pricing": "Free",
   "keywords": [
      "RSL",
      "RStyle",
      "R-Style"
   ],
   "engines": {
      "vscode": "^1.90.0"
   },
   "main": "./client/out/extension",
   "contributes": {
      "languages": [
         {
            "id": "rsl",
            "aliases": [
               "RSL Macro",
               "rsl",
               "RSL"
            ],
            "extensions": [
               ".mac"
            ],
            "configuration": "./language-configuration.json"
         },
         {
            "id": "fchanges",
            "extensions": [
               ".txt"
            ],
            "filenames": [
               "fchanges"
            ],
            "configuration": "./language-configuration.json"
         }
      ],
      "grammars": [
         {
            "language": "fchanges",
            "scopeName": "source.txt",
            "path": "./syntaxes/fchanges.tmLanguage.json"
         },
         {
            "language": "rsl",
            "scopeName": "source.mac",
            "path": "./syntaxes/rsl.tmLanguage.json",
            "balancedBracketScopes": [
               "*"
            ],
            "unbalancedBracketScopes": [
               "comment.block.rsl",
               "comment.line.double-slash.rsl"
            ]
         },
         {
            "scopeName": "OLcomment.injection",
            "path": "./syntaxes/rsl.OLinjection.json",
            "injectTo": [
               "source.mac"
            ]
         },
         {
            "scopeName": "MLcomment.injection",
            "path": "./syntaxes/rsl.MLinjection.json",
            "injectTo": [
               "source.mac"
            ]
         },
         {
            "scopeName": "SQLString.injection",
            "path": "./syntaxes/rsl.SQLinjection.json",
            "injectTo": [
               "source.mac"
            ]
         },
         {
            "scopeName": "SQLSquareBrackets.injection",
            "path": "./syntaxes/rsl.SQL_SB_injection.json",
            "injectTo": [
               "source.mac"
            ]
         }
      ],
      "snippets": [
         {
            "language": "rsl",
            "path": "./snippets/snippets.json"
         }
      ],
      "commands": [
         {
            "command": "extension.insertQueryFromClipboard",
            "title": "Вставить запрос из буфера"
         },
         {
            "command": "extension.copyQueryToClipboard",
            "title": "Копировать запрос в буфер"
         }
      ],
      "menus": {
         "editor/context": [
            {
               "when": "resourceLangId == rsl",
               "command": "extension.insertQueryFromClipboard",
               "group": "9_cutcopypaste"
            },
            {
               "when": "resourceLangId == rsl",
               "command": "extension.copyQueryToClipboard",
               "group": "9_cutcopypaste"
            }
         ]
      },
      "configuration": {
         "type": "object",
         "title": "RSL configuration",
         "properties": {
            "RSLanguageServer.import": {
               "scope": "window",
               "type": "string",
               "enum": [
                  "ДА",
                  "НЕТ"
               ],
               "default": "ДА",
               "description": "Подгружать импортируемые макросы."
            },
            "rsl-plus.programmerName": {
               "type": "string",
               "default": "RS Programmer",
               "description": "Имя разработчика для заголовков RSL-файлов"
            },
            "RSLanguageServer.diagnostics.enabled": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Включить диагностику RSL в панели Problems."
            },
            "RSLanguageServer.diagnostics.deprecatedDeclarations": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Показывать устаревшие объявления RECORD и ARRAY."
            },
            "RSLanguageServer.diagnostics.structure": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Проверять скобки, END, ELSE, повторные объявления и Import."
            },
            "RSLanguageServer.diagnostics.unusedVariables": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Предупреждать о неиспользуемых локальных объявлениях."
            },
            "RSLanguageServer.diagnostics.unusedImports": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Предупреждать о неиспользуемых известных модулях."
            },
            "RSLanguageServer.diagnostics.debugBreak": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Предупреждать об оставленном DEBUGBREAK."
            },
            "RSLanguageServer.diagnostics.useBeforeDeclaration": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Проверять использование локальной переменной до объявления."
            },
            "RSLanguageServer.diagnostics.ambiguousReferences": {
               "scope": "resource",
               "type": "boolean",
               "default": true,
               "description": "Проверять неоднозначные ссылки из импортированных модулей."
            },
            "RSLanguageServer.diagnostics.maxProblems": {
               "scope": "resource",
               "type": "integer",
               "minimum": 0,
               "default": 200,
               "description": "Максимальное количество сообщений Problems на открытый файл."
            }
         }
      },
      "configurationDefaults": {
         "[rsl]": {
            "editor.semanticHighlighting.enabled": true
         }
      }
   },
   "activationEvents": [
      "onLanguage:rsl"
   ],
   "scripts": {
      "vscode:prepublish": "npm test",
      "compile": "tsc -b",
      "watch": "tsc -b -w",
      "test:lexer": "npm run compile && node tests/lexer.test.js",
      "test:formatter": "npm run compile && node tests/formatter.test.js",
      "test:folding": "npm run compile && node tests/folding.test.js",
      "test:definition": "npm run compile && node tests/definition.test.js",
      "test:parser": "npm run compile && node tests/parser-optimized.test.js",
      "test:scope": "npm run compile && node tests/scope-index.test.js",
      "test": "npm run compile && node tests/run-all.js",
      "postinstall": "npm ci --prefix client && npm ci --prefix server",
      "test:diagnostics": "npm run compile && node tests/diagnostics.test.js",
      "test:features": "npm run compile && node tests/language-features.test.js",
      "test:architecture": "npm run compile && node tests/pipeline-architecture.test.js && node tests/semantic-resolution.test.js && node tests/reference-index.test.js"
   },
   "devDependencies": {
      "@types/node": "22.16.5",
      "typescript": "5.9.3"
   }
}
